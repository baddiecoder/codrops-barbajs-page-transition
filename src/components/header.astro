---
import { examples } from "../scripts/data";

const { pathname } = Astro.url;
const example = pathname.split("/")[1];
---

<header class="header">
  <nav class="nav">
    <a
      href={!examples.some((example) => pathname.includes(example))
        ? "/"
        : `/${example}`}
      class="nav__link"
      data-transition-example={example}
      data-route="/"
    >
      Home
    </a>
    <h1 class="nav__title">balss</h1>
    <a
      href={!examples.some((example) => pathname.includes(example))
        ? "/about"
        : `/${example}/about`}
      class="nav__link"
      data-transition-example={example}
      data-route="/about"
    >
      About
    </a>
  </nav>
</header>
