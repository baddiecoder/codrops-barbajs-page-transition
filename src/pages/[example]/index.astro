---
import Layout from "../../layouts/Layout.astro";
import { examples } from "../../scripts/data";

export const getStaticPaths = () => {
  return examples.map((ex) => {
    return { params: { example: ex }, props: { example: ex } };
  });
};

const { example } = Astro.props;
---

<Layout uid={`home__${example}`}>
  <div class="content home">
    <p
      data-motion-text
      data-motion-text-split="lines"
      data-motion-text-duration="0.95"
      data-motion-text-stagger="0.15"
      class="description__home"
    >
      Indonesia, officially the Republic of Indonesia, is a country in Southeast
      Asia and Oceania, between the Indian and Pacific oceans. Comprising over
      17,000 islands, including Sumatra, Java, Sulawesi, and parts of Borneo and
      New Guinea, Indonesia is the world's largest archipelagic state and the
      14th-largest country by area, at 1,904,569 square kilometres (735,358
      square miles). Indonesia has significant areas of wilderness that support
      one of the world's highest levels of biodiversity.
    </p>
    <h1
      class="title__home"
      data-motion-text
      data-motion-text-split="chars"
      data-motion-text-duration="0.75"
    >
      indonesia
    </h1>
  </div>
</Layout>
