---
import Layout from "../../layouts/Layout.astro";
import { examples } from "../../scripts/data";

export const getStaticPaths = () => {
  return examples.map((ex) => {
    return { params: { example: ex }, props: { example: ex } };
  });
};

const { example } = Astro.props;
---

<Layout uid={`about__${example}`}>
  <div class="content">
    <h1>About</h1>
  </div>
</Layout>
